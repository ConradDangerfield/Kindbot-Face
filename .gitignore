# ============================================================================
# KindBot Face Engine — repo .gitignore
# ============================================================================

# ----- Secrets & env files --------------------------------------------------
# Ignore every .env and .env.<anything>, anywhere in the tree...
.env
.env.*
*.env
# ...EXCEPT the committed templates:
!**/.env.example

# Belt-and-braces: be explicit about the Hostinger VPS secret.
deploy/.env

# Misc credentials
*.pem
*.key
*token.json*
*credentials.json*
.credentials

# ----- Node / React / Express -----------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# React (CRA / craco) build artifacts
build/
/build
dist/
dist
.cache/

# Next.js (kept in case anything reuses this template)
.next/
out/
next-env.d.ts
*.tsbuildinfo

# Test coverage
coverage/

# Node logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ----- Python / FastAPI -----------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
venv/
.venv/
.python-version

# ----- KindBot-specific -----------------------------------------------------
# User-uploaded MP4 assets — large binaries, often per-deployment.
# Track them via the README (and the README in the folder), not git.
deploy/public/assets/mp4/*.mp4
frontend/public/assets/mp4/*.mp4

# Test reports (generated by testing agent / pytest)
test_reports/
**/test_reports/

# Memory file with test credentials
memory/test_credentials.md

# ----- IDE / Editor / OS ---------------------------------------------------
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo
.ipynb_checkpoints/

# ----- Deployment artifacts -------------------------------------------------
.vercel/

# ----- Archives & big binaries ---------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.pack
*.deb
*.dylib
-e 

# KindBot Face Engine — Hostinger VPS environment
#
# Copy this file to `.env` next to docker-compose.yml on your VPS:
#     cp .env.example .env
#     nano .env
#
# Then bring it up:
#     docker compose up -d --build

# ===== REQUIRED =============================================================

# Bearer token for /api/mode/* and /api/say. Generate a fresh one with:
#     openssl rand -base64 32
KINDBOT_API_TOKEN=replace-me-with-openssl-rand-base64-32

# Public hostname Traefik routes to. Must resolve via DNS to your VPS.
KINDBOT_DOMAIN=kindbot.your-domain.tld

# ===== OPTIONAL — TTS (/api/say) ===========================================

# OpenAI API key. Without this, /api/say returns 503 (the rest of the engine
# works fine). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# tts-1 (fast, cheaper) or tts-1-hd (higher quality, slower, more expensive)
KINDBOT_TTS_MODEL=tts-1

# alloy | ash | coral | echo | fable | nova | onyx | sage | shimmer
KINDBOT_TTS_VOICE=nova

# ===== OPTIONAL — Traefik wiring ============================================
# Override only if your Traefik instance uses different names than the
# defaults below.

# External Docker network your Traefik container is attached to.
TRAEFIK_NETWORK=traefik-ypta

# Traefik entrypoint name for HTTPS (defined in your Traefik static config).
TRAEFIK_ENTRYPOINT=websecure

# Traefik cert resolver name (defined in your Traefik static config).
TRAEFIK_CERT_RESOLVER=letsencrypt

# ===== OPTIONAL — CORS ======================================================
# Comma-separated list of origins allowed to call the API from a browser.
# Leave as `*` if KindBot is the only consumer.
CORS_ORIGINS=*
